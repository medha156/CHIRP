# =============================================================================
# CHIRP — .gitignore
# Python / Poetry / ML project
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env
.env.*

# ---------------------------------------------------------------------------
# Poetry
# ---------------------------------------------------------------------------
poetry.lock        # committed only if this is a library; omit for apps
# Uncomment the line above if you want to pin the lock file for reproducibility

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb             # track notebooks intentionally — remove this line to commit them
profile_default/
ipython_config.py

# ---------------------------------------------------------------------------
# Data — never commit raw/processed video or large binaries
# ---------------------------------------------------------------------------
data/raw/
data/processed/
# data/synthetic/ is procedurally generated by
# experiments/generate_synthetic_data.py — don't commit
data/synthetic/
# Real-data working directories — built by experiments/build_index.py
# from the 3 free sources (VB100, Birds-525, iNaturalist). Don't commit
# the actual photos/videos; let users re-pull via the documented commands.
data/vb100/
data/birds525/
data/inaturalist/
data/merged/
# Split CSVs are typically generated; commit only if small and deliberate.
data/splits/*.csv
*.mp4
*.avi
*.mov
*.mkv
*.h5
*.hdf5
*.pkl
*.parquet

# ---------------------------------------------------------------------------
# Model weights & checkpoints
# ---------------------------------------------------------------------------
outputs/
*.pt
*.pth
*.ckpt
*.bin
*.safetensors

# ---------------------------------------------------------------------------
# Experiment tracking
# ---------------------------------------------------------------------------
wandb/
mlruns/
.aim/
lightning_logs/

# ---------------------------------------------------------------------------
# OS / editor noise
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ---------------------------------------------------------------------------
# Type checking
# ---------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
.pytype/

# ---------------------------------------------------------------------------
# Ruff / linter caches
# ---------------------------------------------------------------------------
.ruff_cache/
